require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, "16.0"
prepare_react_native_project!

target 'FacesRegistration' do
  pod 'FacesKit', :path => '../../../ios'
  pod 'FacesCaptureKit', :path => '../../../ios-capture'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/..",
  )

  # AppReveal is SPM-only — added via XcodeGen (project.yml), not CocoaPods.

  post_install do |installer|
    react_native_post_install(installer, :mac_catalyst_enabled => false)
  end
end
