{
  "name": "@unlikeotherai/faces",
  "version": "0.1.0",
  "description": "Browser Web Worker recognition layer for Faces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker/recognitionWorker.d.ts",
      "import": "./dist/worker/recognitionWorker.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/worker/recognitionWorker.ts --format esm --dts --out-dir dist --splitting false --clean",
    "check": "pnpm run typecheck && pnpm run test",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
